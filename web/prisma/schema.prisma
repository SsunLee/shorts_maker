generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserSettings {
  userId    String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAutomationTemplateCatalog {
  userId    String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAutomationScheduleState {
  userId    String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAccount {
  userId    String   @id
  email     String?
  name      String?
  role      String   @default("user")
  isActive  Boolean  @default(true)
  expiresAt DateTime?
  accessCode UserAccessCode?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserWorkflowCatalog {
  userId    String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAccessCode {
  userId          String   @unique
  codeHash        String   @unique
  codeHint        String
  createdByUserId String?
  isActive        Boolean  @default(true)
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  account         UserAccount @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

