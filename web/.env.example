# App URL used to build absolute asset URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000

# Auth (Google Login)
NEXTAUTH_URL=http://localhost:3000
# Use a long random string (openssl rand -base64 32)
NEXTAUTH_SECRET=
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated super admin emails for /admin/users access.
SUPER_ADMIN_EMAILS=
# Same list exposed to client for nav visibility.
NEXT_PUBLIC_SUPER_ADMIN_EMAILS=

# Database (required for account-scoped settings/templates on production)
DATABASE_URL=

# Vercel cron auth secret for /api/cron/automation
CRON_SECRET=

# Optional local settings isolation
# - SETTINGS_NAMESPACE: creates data/settings.{namespace}.json
# - SETTINGS_FILE: exact file path (overrides SETTINGS_NAMESPACE)
# SETTINGS_NAMESPACE=dev-3000
# SETTINGS_FILE=data/settings.dev-3000.json

# Optional automation data isolation
# - AUTOMATION_NAMESPACE: creates namespaced automation files
#   data/automation-template.{namespace}.json
#   data/automation-schedule.{namespace}.json
# - AUTOMATION_TEMPLATE_FILE / AUTOMATION_SCHEDULE_FILE: exact file paths
#   (override AUTOMATION_NAMESPACE)
# AUTOMATION_NAMESPACE=dev-3000
# AUTOMATION_TEMPLATE_FILE=data/automation-template.dev-3000.json
# AUTOMATION_SCHEDULE_FILE=data/automation-schedule.dev-3000.json

# AI provider: auto | gemini | openai
AI_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_TIMEOUT_MS=120000
OPENAI_IMAGE_RETRY_COUNT=0
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Gemini (auto-selected when key exists in auto mode)
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_IMAGE_TIMEOUT_MS=45000
GEMINI_IMAGE_RETRY_COUNT=0
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Google Sheets (service account)
GSHEETS_SPREADSHEET_ID=
GSHEETS_SHEET_NAME=Shorts
GSHEETS_CLIENT_EMAIL=
GSHEETS_PRIVATE_KEY=

# YouTube OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/oauth2callback
YOUTUBE_REFRESH_TOKEN=

# External local video engine
VIDEO_ENGINE_URL=http://localhost:8000
# Optional fallback endpoint (e.g. Cloud Run)
VIDEO_ENGINE_FALLBACK_URL=
# Optional prioritized list (comma/newline separated). When set, this takes highest priority.
# Example: VIDEO_ENGINE_URLS=https://pc-engine.example.com,https://shorts-video-engine-xxx.a.run.app
VIDEO_ENGINE_URLS=
# Per-endpoint timeout in ms (default: 900000 = 15 min)
VIDEO_ENGINE_TIMEOUT_MS=900000
# Shared secret sent as X-Video-Engine-Secret header (optional but recommended for public endpoints)
VIDEO_ENGINE_SHARED_SECRET=

# Optional object storage (S3 Standard)
# When S3_BUCKET is set, generated assets and rendered videos are mirrored to S3.
# Bucket policy/public CDN should allow GET for uploaded objects.
S3_REGION=
S3_BUCKET=
S3_PREFIX=shorts-maker
S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
